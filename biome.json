{
  "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
  "vcs": {
    "enabled": false,
    "clientKind": "git",
    "useIgnoreFile": false
  },
  "files": {
    "includes": ["src/**"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,

      "complexity": {
        "noUselessCatch": "error",
        "noUselessTypeConstraint": "error"
      },

      "correctness": {
        "noConstAssign": "error",
        "noEmptyPattern": "error",
        "noGlobalObjectCalls": "error",
        "noInvalidConstructorSuper": "error",
        "noSetterReturn": "error",
        "noUnreachable": "error",
        "noUndeclaredVariables": "error",
        "useIsNan": "error",
        "useValidTypeof": "error"
      },

      "style": {
        "useConst": "error",
        "useNamingConvention": {
          "level": "error",
          "options": {
            "strictCase": false,
            "conventions": [
              {
                "selector": {
                  "kind": "interface"
                },
                "formats": ["PascalCase"]
              },
              {
                "selector": {
                  "kind": "typeAlias"
                },
                "formats": ["PascalCase"]
              },
              {
                "selector": { "kind": "typeParameter" },
                "formats": ["PascalCase"]
              },
              {
                "selector": {
                  "kind": "typeMember"
                },
                "formats": ["camelCase", "snake_case", "PascalCase"]
              },
              {
                "selector": {
                  "kind": "objectLiteralProperty"
                },
                "formats": ["camelCase", "snake_case", "CONSTANT_CASE", "PascalCase"]
              },
              {
                "selector": {
                  "kind": "importAlias"
                },
                "formats": ["PascalCase", "camelCase", "CONSTANT_CASE"]
              },
              {
                "selector": {
                  "kind": "exportAlias"
                },
                "formats": ["PascalCase", "camelCase", "CONSTANT_CASE"]
              },
              {
                "selector": {
                  "kind": "enum"
                },
                "formats": ["PascalCase"]
              },
              {
                "selector": {
                  "kind": "enumMember"
                },
                "formats": ["CONSTANT_CASE"]
              }
            ]
          }
        }
      },

      "suspicious": {
        "noAsyncPromiseExecutor": "error",
        "noAssignInExpressions": "error",
        "noDuplicateCase": "error",
        "noDuplicateObjectKeys": "error",
        "noDuplicateParameters": "error",
        "noFunctionAssign": "error",
        "noImportAssign": "error",
        "noRedeclare": "error",
        "useAwait": "error",
        "noVar": "error"
      }
    }
  },

  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
